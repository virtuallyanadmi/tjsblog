---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Jonathan Stewart"
  description="The page you are looking for doesn't exist or has been moved."
>
  <section class="flex-grow flex items-center justify-center py-24 px-4">
    <div class="text-center max-w-lg mx-auto">
      <p class="text-8xl font-display font-bold gradient-text mb-4">404</p>
      <h1 class="text-3xl md:text-4xl font-display font-bold text-gray-900 dark:text-white mb-4">
        Page Not Found
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">
          Go Home
        </a>
        <a href="/blog" class="btn-secondary">
          Browse the Blog
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
