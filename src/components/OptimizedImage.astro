---
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  quality?: number;
  className?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  src,
  alt,
  width = 800,
  height = 600,
  quality = 80,
  className = '',
  loading = 'lazy',
  fetchpriority = 'auto',
} = Astro.props;

const isRemote = src.startsWith('http://') || src.startsWith('https://');
---

{isRemote ? (
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding={loading === 'eager' ? 'sync' : 'async'}
    fetchpriority={fetchpriority}
    class={`rounded-lg w-full max-w-2xl mx-auto ${className}`}
  />
) : (
  <Image
    src={src as any}
    alt={alt}
    width={width}
    height={height}
    quality={quality}
    loading={loading}
    decoding={loading === 'eager' ? 'sync' : 'async'}
    fetchpriority={fetchpriority}
    class={`rounded-lg w-full max-w-2xl mx-auto ${className}`}
  />
)}
