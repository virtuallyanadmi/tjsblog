# Image CDN (Cloudflare R2)
PUBLIC_IMAGE_CDN_URL=https://images.yourdomain.com

# Contact Form (Choose one service)
# Option 1: Web3Forms (Recommended - Free tier available)
# Get your access key at https://web3forms.com/
PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key

# Option 2: Formspree (Alternative - Free tier available)
# Get your form ID at https://formspree.io/
# PUBLIC_FORMSPREE_ID=your_formspree_id

# Site URL (for sitemap and SEO)
PUBLIC_SITE_URL=https://yourdomain.com

# Giscus Comments (GitHub Discussions)
# Get these values from https://giscus.app after enabling GitHub Discussions
PUBLIC_GISCUS_REPO=your-username/your-repo
PUBLIC_GISCUS_REPO_ID=your_repo_id
PUBLIC_GISCUS_CATEGORY=Blog Comments
PUBLIC_GISCUS_CATEGORY_ID=your_category_id
